{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist/",
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "target": "ES2020",
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true
  },
  "include": ["serial.ts"]
}
